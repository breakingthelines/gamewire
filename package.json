{
  "name": "@breakingthelines/gamewire",
  "version": "0.0.3",
  "description": "Provider adapter library and ingestion runtime for BTL game data",
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/breakingthelines/gamewire.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "imports": {
    "#/*": "./src/*"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./adapters/statsbomb-open": {
      "types": "./dist/adapters/statsbomb-open/index.d.ts",
      "import": "./dist/adapters/statsbomb-open/index.js"
    },
    "./adapters/api-football": {
      "types": "./dist/adapters/api-football/index.d.ts",
      "import": "./dist/adapters/api-football/index.js"
    },
    "./worker": {
      "types": "./dist/worker/index.d.ts",
      "import": "./dist/worker/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "bunchee --external @breakingthelines/protos",
    "check": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "start:worker": "bun run src/worker/server.ts",
    "dev:worker": "bun --watch run src/worker/server.ts",
    "test": "vitest"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.0.0"
  },
  "devDependencies": {
    "@breakingthelines/protos": "0.7.0",
    "@types/node": "^24.10.1",
    "@vitest/coverage-v8": "4.0.16",
    "bunchee": "^6.9.3",
    "oxfmt": "^0.21.0",
    "oxlint": "^1.36.0",
    "typescript": "~5.9.3",
    "vitest": "4.0.16"
  }
}
